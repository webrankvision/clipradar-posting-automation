# ============================================================
# CLIPRADAR — AUTOMATED POSTING SYSTEM
# Copy this file to .env and fill in your credentials
# ============================================================

# ---- ANTHROPIC (Claude AI) --------------------------------
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---- ZERNIO (posts to all 4 platforms) --------------------
# Get at: https://app.zernio.com → Settings → API Keys
# Connect your social accounts in the Zernio dashboard first.
# Then copy each connected account's ID from the Accounts tab.
ZERNIO_API_KEY=your_zernio_api_key_here
ZERNIO_ACCOUNT_TIKTOK=your_zernio_tiktok_account_id_here
ZERNIO_ACCOUNT_INSTAGRAM=your_zernio_instagram_account_id_here
ZERNIO_ACCOUNT_FACEBOOK=your_zernio_facebook_account_id_here
ZERNIO_ACCOUNT_YOUTUBE=your_zernio_youtube_account_id_here

# ---- GOOGLE DRIVE (inbox for videos from iPhone) ----------
# GOOGLE_DRIVE_FOLDER_ID: the ID from the URL of your Drive inbox folder
#   Example: https://drive.google.com/drive/folders/1ABC123xyz → ID is 1ABC123xyz
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# GOOGLE_SERVICE_ACCOUNT_FILE: path to the JSON key file downloaded
#   from Google Cloud Console when creating the service account
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/clipradar-service-account.json

# ---- FUNNEL SETTINGS --------------------------------------
# The link sent to people who comment "SYSTEM" via ManyChat
EBOOK_LINK=https://build2millions.com/

# ---- PLATFORM TOGGLES -------------------------------------
# Set to "false" to disable a platform without removing credentials
ENABLE_TIKTOK=true
ENABLE_INSTAGRAM=true
ENABLE_FACEBOOK=true
ENABLE_YOUTUBE=true

# ---- WHISPER (transcription) ------------------------------
# Model size: tiny, base, small, medium, large-v3
# Larger = more accurate, slower. base is recommended for speed.
WHISPER_MODEL=base

# ---- POSTING SCHEDULE (US Eastern Time — HH:MM 24-hour) ---
# Each platform has 2 slots per day.
# 1 video uses slot 1. 2 videos use both slots.
# 3+ videos fill today's slots then roll to the next day.

SCHEDULE_TIKTOK_1=08:00
SCHEDULE_TIKTOK_2=20:00

SCHEDULE_INSTAGRAM_1=08:00
SCHEDULE_INSTAGRAM_2=18:00

SCHEDULE_YOUTUBE_1=13:00
SCHEDULE_YOUTUBE_2=18:00

SCHEDULE_FACEBOOK_1=09:00
SCHEDULE_FACEBOOK_2=20:00
